# ═══════════════════════════════════════════
#  GHOST-MD v2.0 Environment Variables
//  Set these on OnRender → Environment tab
# ═══════════════════════════════════════════

# Bot display name
BOTNAME=GHOST-MD

# Command prefix (default: .)
PREFIX=.

# Owner WhatsApp number(s), comma-separated (with country code, no +)
OWNER=2547XXXXXXXX

# Developer number(s), comma-separated
DEV=2547XXXXXXXX

# Mode: public (anyone can use) | private (owner only)
MODE=public

# ─── Features ───
ANTICALL=off
AUTOREAD=off
ANTILINK=off
AUTOBIO=off
AUTOLIKE=off
AUTOVIEW=off
ANTIDELETE=off
ANTIBOT=off
ANTITAG=off
GPTDM=off
WELCOME=on

# Bad words filter (comma-separated)
BAD_WORDS=fuck,shit,bitch

# Timezone for auto-bio
TZ=Africa/Nairobi

# Port (OnRender sets this automatically)
# PORT=10000